# ============================================================
# ui_selenium_bdd — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter .env sur GitHub
# ============================================================

# LLM — Groq (obligatoire pour les agents IA)
GROQ_API_KEY=gsk_your_key_here

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Jira (optionnel)
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT=QA

# GitHub (optionnel — pour ci-agent.py PR et releases)
GITHUB_TOKEN=ghp_your_token_here

# Configuration Selenium (défauts dans src/test/resources/properties/)
# URL cible définie dans local.properties : https://automationexercise.com
