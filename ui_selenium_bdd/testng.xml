<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cucumber MultiBrowser Parallel" parallel="tests" thread-count="1">

  <test name="Cucumber - Chrome">
    <parameter name="browser" value="chrome"/>
    <classes>
      <class name="com.qacart.todo.runners.ParallelRunnerTest"/>
    </classes>
  </test>

  <test name="Cucumber - Firefox">
    <parameter name="browser" value="firefox"/>
    <classes>
      <class name="com.qacart.todo.runners.ParallelRunnerTest"/>
    </classes>
  </test>

</suite>