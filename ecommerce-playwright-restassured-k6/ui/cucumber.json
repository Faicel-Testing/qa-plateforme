{
  "default": {
    "require": ["steps/**/*.ts", "support/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress",
      "allure-cucumberjs/reporter"
    ],
    "formatOptions": {
      "resultsDir": "allure-results"
    },
    "paths": ["features/**/*.feature"],
    "parallel": 2
  }
}
