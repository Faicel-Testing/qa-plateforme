# ============================================================
# Variables d'environnement — perf_k6_qacart
# ============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# IMPORTANT : Ne jamais committer .env dans git !
# ============================================================

BASE_URL=https://qacart-todo.herokuapp.com

# LLM — Groq (cloud, gratuit) ou Ollama (local fallback)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Jira — pour planning-agent.js / codegen-agent.js / ci-agent.js
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT=SCRUM

# Notifications — optionnel (reporting-agent.js)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/YOUR/WEBHOOK/URL
