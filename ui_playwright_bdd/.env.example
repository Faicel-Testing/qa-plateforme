# ── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://qacart-todo.herokuapp.com
HEADLESS=false
BROWSER=chromium

# ── Groq (cloud gratuit — recommandé) ─────────────────────────────────────────
# Clé gratuite sur : https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Ollama (local — fallback si pas de clé Groq) ──────────────────────────────
# Install : https://ollama.com/download  puis : ollama pull qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434

# ── Jira ──────────────────────────────────────────────────────────────────────
# Token API : https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your_jira_api_token_here
JIRA_PROJECT=SCRUM
